# Database
DATABASE_URL=postgresql://lifeuser:lifepassword@localhost:5432/lifedashboard

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Node Environment
NODE_ENV=development

# Infrastructure Settings

# Logging (debug|info|warn|error)
LOG_LEVEL=debug

# Feature Flags (override defaults)
FEATURE_FLAG_GOOGLE_CALENDAR_INTEGRATION=true
FEATURE_FLAG_HEALTH_TRACKING=false
FEATURE_FLAG_FINANCE_INTEGRATION=false
FEATURE_FLAG_TASK_MANAGEMENT=false
FEATURE_FLAG_ANALYTICS_TRACKING=false
FEATURE_FLAG_ERROR_REPORTING=false

# Analytics (uncomment when configured)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# MIXPANEL_TOKEN=your-mixpanel-token

# Error Tracking (uncomment when configured)
# SENTRY_DSN=https://xxx@sentry.io/xxx
# SENTRY_ENVIRONMENT=development
